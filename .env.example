# ============================================================
# Daily Digest - Environment Variables
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit .env to Git. It's in .gitignore by default.
# ============================================================

# --- Anthropic API ---
# Get your key at: https://console.anthropic.com/settings/keys
# Model defaults to claude-sonnet-4-20250514 (cost-efficient for summarization)
ANTHROPIC_API_KEY=sk-ant-your-key-here
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# --- Email (Gmail) ---
# Create a dedicated Gmail account for the bot (e.g., mydigest.bot@gmail.com)
# Then generate an App Password:
#   1. Go to myaccount.google.com/security
#   2. Enable 2-Step Verification (required)
#   3. Go to myaccount.google.com/apppasswords
#   4. Create an app password for "Mail"
#   5. Copy the 16-character password below (no spaces)
GMAIL_ADDRESS=your-digest-bot@gmail.com
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# --- Recipient ---
# The email address where you want to receive digests
RECIPIENT_EMAIL=your-personal-email@example.com
